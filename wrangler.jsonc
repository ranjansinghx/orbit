{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "orbit",
  "main": ".open-next/worker.js",
  // Keep this at or after 2024-09-23 — required for @opennextjs/cloudflare.
  // Bump it to today's date whenever you touch this file.
  "compatibility_date": "2026-07-13",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  }
}
