# Copy this file to .env.local and fill in the values from your Supabase
# project's Settings → API page.

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# For push notifications — see supabase/functions/send-push/README.md
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key

# Server-only — from Settings → API → service_role (the "secret" one, not
# anon). NEVER prefix this with NEXT_PUBLIC_ or it gets bundled into the
# browser. Used only by app/api/account/delete for account deletion.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional — your production domain, used to resolve absolute URLs for
# Open Graph / Twitter card images. Falls back to Vercel's own deployment
# URL automatically if you skip this, so it's only worth setting once you
# have a custom domain.
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Optional — bot protection on signup/signin/password-reset via Cloudflare
# Turnstile. Get a site key from https://dash.cloudflare.com/?to=/:account/turnstile
# (free, no domain/Cloudflare Pages needed — just the Turnstile product).
# You must ALSO enable "Captcha protection" in Supabase → Authentication →
# Settings and paste the matching Turnstile SECRET key there — the site key
# below only renders the widget, Supabase is what actually verifies it.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key
